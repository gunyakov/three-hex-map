{
  "name": "three-hex-map",
  "version": "0.5.0",
  "description": "A civ like 3D hexagonal terrain map based on three.js, rendered via instancing/shaders.",
  "type": "module",
  "main": "dist/hex-map.js",
  "module": "dist/hex-map.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/hex-map.mjs",
      "require": "./dist/hex-map.js"
    }
  },
  "unpkg": "dist/hex-map.global.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build:lib": "tsup && tsc -p tsconfig.build.json && rollup -c rollup.config.global.mjs",
    "build:demo": "npm run build:lib && node scripts/copy-demo-assets.cjs",
    "build": "npm run build:demo",
    "server": "npx http-server public -c-1 -p 3000",
    "start": "npm run build && npm run server",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gunyakov/three-hex-map.git"
  },
  "keywords": [
    "civilization",
    "hex map",
    "game map",
    "threejs",
    "webgl"
  ],
  "author": "Oleg Gunyakov",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/gunyakov/three-hex-map/issues"
  },
  "homepage": "https://github.com/gunyakov/three-hex-map#readme",
  "peerDependencies": {
    "three": ">=0.160.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/three": "^0.185.0",
    "dat.gui": "^0.7.9",
    "rollup": "^4.62.2",
    "stats.js": "^0.17.0",
    "three": "^0.185.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "robust-point-in-polygon": "^1.0.3"
  }
}
